name: yt-dlp-test

on:
  workflow_dispatch:

jobs:
  test:
    runs-on: ubuntu-latest

    steps:

    - name: Checkout
      uses: actions/checkout@v4


    - name: Install tools
      run: |
        sudo apt update
        sudo apt install -y ffmpeg python3-pip curl unzip


    - name: Install Deno
      run: |
        curl -fsSL https://deno.land/install.sh | sh

        echo "$HOME/.deno/bin" >> $GITHUB_PATH

        $HOME/.deno/bin/deno --version


    - name: Install yt-dlp
      run: |
        python3 -m pip install -U yt-dlp


    - name: Versions
      run: |
        yt-dlp --version
        deno --version


    - name: YouTube download test
      run: |
        yt-dlp \
        --cookies cookies.txt \
        --js-runtimes deno \
        --remote-components ejs:github \
        --no-check-certificates \
        --force-ipv4 \
        --extractor-args "youtube:player_client=web" \
        -f "best[height<=720]/best" \
        -o "video.%(ext)s" \
        "https://youtu.be/-6a9RSBeADw?si=x2jOGjwY3exVVADnv"


    - name: Check
      run: |
        ls -lh
        file video.*
